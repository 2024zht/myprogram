/**app.wxss**/
page {
  background: #f8f5f0;
  font-family: 'PingFang SC', sans-serif;
  min-height: 100vh;
}

.container {
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

button {
  background: initial;
}

button:focus {
  outline: 0;
}

button::after {
  border: none;
}

.btn-primary {
  background-color: #d4739a;
  color: #ffffff;
  border-radius: 40rpx;
  font-size: 30rpx;
  padding: 16rpx 0;
  text-align: center;
  border: none;
}

.btn-primary::after {
  border: none;
}

.card {
  background-color: #ffffff;
  border-radius: 20rpx;
  margin: 20rpx 24rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.input-field {
  background-color: #f8f5f0;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333;
}

.tag {
  display: inline-block;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.tag-refund {
  background-color: #fbe0e0;
  color: #e54545;
}

.tag-cancel {
  background-color: #e0e0e0;
  color: #999999;
}

.tag-done {
  background-color: #e0f0e0;
  color: #4caf50;
}
