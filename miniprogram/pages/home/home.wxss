/* pages/home/home.wxss */

/* 整页滚动容器 */
.page-scroll {
  height: 100vh;
  display: block;
}

/* 顶部 banner（自然大小，滚动时上移消失） */
.banner {
  width: 100%;
}

.banner-img {
  width: 100%;
  display: block;
}

/* 主体区域：sticky 吸顶，banner 滚走后贴在顶部 */
.main-wrap {
  position: sticky;
  top: 0;
}

.main-content {
  display: flex;
  height: 100vh;
}

/* 左侧分类栏 */
.sidebar {
  width: 180rpx;
  flex: none;
  background: #f8f5f0;
}

.sidebar-item {
  padding: 28rpx 16rpx;
  text-align: center;
  font-size: 26rpx;
  color: #666;
  border-left: 6rpx solid transparent;
  transition: all 0.2s;
}

.sidebar-item.active {
  color: #d4739a;
  background: #fff;
  border-left-color: #d4739a;
  font-weight: 500;
}

.sidebar-empty {
  padding: 40rpx 16rpx;
  text-align: center;
  font-size: 24rpx;
  color: #ccc;
}

/* 右侧商品区 */
.product-area {
  flex: 1;
  background: #fff;
  padding: 16rpx;
}

.loading-text {
  text-align: center;
  padding: 60rpx;
  color: #999;
  font-size: 26rpx;
}

.empty-state {
  display: flex;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-text {
  color: #ccc;
  font-size: 28rpx;
}

.product-card {
  display: flex;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  padding: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.product-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.product-info {
  flex: 1;
  margin-left: 16rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.product-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.product-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.product-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
}

.product-price {
  font-size: 32rpx;
  color: #d4739a;
  font-weight: 600;
}

.product-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.product-stock {
  font-size: 22rpx;
  color: #bbb;
}

.product-out {
  font-size: 22rpx;
  color: #e54545;
}

/* 加号按钮 */
.btn-add {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #d4739a, #e891b0);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(212, 115, 154, 0.3);
}

.btn-add-text {
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1;
}

.bottom-spacer {
  height: 140rpx;
}

/* 购物车悬浮条 */
.cart-bar {
  position: fixed;
  bottom: 110rpx;
  left: 24rpx;
  right: 24rpx;
  height: 96rpx;
  background: #333;
  border-radius: 48rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 12rpx 0 28rpx;
  z-index: 90;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.2);
}

.cart-bar-left {
  display: flex;
  align-items: center;
}

.cart-icon-wrap {
  position: relative;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cart-icon-img {
  width: 48rpx;
  height: 48rpx;
}

.cart-badge {
  position: absolute;
  top: -8rpx;
  right: -12rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  font-size: 20rpx;
  color: #fff;
  background: #d4739a;
  border-radius: 16rpx;
  padding: 0 8rpx;
}

.cart-bar-text {
  color: #fff;
  font-size: 26rpx;
  margin-left: 16rpx;
}

.btn-order-bar {
  background: linear-gradient(135deg, #d4739a, #e891b0);
  border-radius: 36rpx;
  padding: 18rpx 36rpx;
}

.btn-order-bar text {
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
}

/* 购物车面板 */
.cart-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 99;
}

.cart-panel {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: #fff;
  border-radius: 30rpx 30rpx 0 0;
  z-index: 100;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.cart-panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.cart-panel-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.cart-clear {
  padding: 8rpx 16rpx;
}

.cart-clear-text {
  font-size: 26rpx;
  color: #999;
}

.cart-panel-body {
  flex: 1;
  padding: 0 30rpx;
  overflow: auto;
}

.cart-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.cart-item-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.cart-item-info {
  flex: 1;
  margin-left: 16rpx;
}

.cart-item-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.cart-item-price {
  font-size: 26rpx;
  color: #d4739a;
  margin-top: 8rpx;
}

.cart-item-qty {
  display: flex;
  align-items: center;
}

.cart-qty-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #f8f5f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #d4739a;
}

.cart-qty-num {
  width: 60rpx;
  text-align: center;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.cart-empty {
  text-align: center;
  padding: 60rpx 0;
  color: #ccc;
  font-size: 28rpx;
}

.cart-panel-footer {
  padding: 16rpx 30rpx 0;
}

/* 备注区域 */
.cart-remark-wrap {
  display: flex;
  align-items: center;
  padding: 16rpx 30rpx;
  border-top: 1rpx solid #f0f0f0;
}

.cart-remark-label {
  font-size: 26rpx;
  color: #666;
  flex-shrink: 0;
  margin-right: 16rpx;
}

.cart-remark-input {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  background: #f8f5f0;
  border-radius: 12rpx;
  padding: 14rpx 20rpx;
}

.btn-order-panel {
  background: linear-gradient(135deg, #d4739a, #e891b0);
  border-radius: 40rpx;
  padding: 22rpx 0;
  text-align: center;
}

.btn-order-panel text {
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
}

/* 用户底部导航 */
.user-tabbar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 110rpx;
  background: #fff;
  display: flex;
  justify-content: space-around;
  align-items: center;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.04);
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 95;
}

.user-tab {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  padding: 10rpx 0;
}

.user-tab-icon {
  font-size: 40rpx;
  line-height: 1;
}

.user-tab-text {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

.user-tab.active .user-tab-text {
  color: #d4739a;
}

/* 商品评分 */
.product-rating {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
}

.star {
  font-size: 24rpx;
  color: #ddd;
  margin-right: 2rpx;
}

.star.star-on {
  color: #f5a623;
}

.rating-text {
  font-size: 22rpx;
  color: #999;
  margin-left: 8rpx;
}

/* 评价面板 */
.rating-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 99;
}

.rating-panel {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: #fff;
  border-radius: 30rpx 30rpx 0 0;
  z-index: 100;
  padding: 30rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.rating-panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.rating-panel-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.rating-panel-close {
  font-size: 40rpx;
  color: #999;
  padding: 0 10rpx;
}

.rating-product-name {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 30rpx;
  text-align: center;
}

.rating-stars {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.rating-star-btn {
  font-size: 64rpx;
  color: #ddd;
  transition: color 0.2s;
}

.rating-star-btn.star-on {
  color: #f5a623;
}

.rating-hint {
  text-align: center;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.rating-content-input {
  width: 100%;
  height: 120rpx;
  font-size: 26rpx;
  color: #333;
  background: #f8f5f0;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  box-sizing: border-box;
  margin-bottom: 20rpx;
}

.rating-panel-footer {
  padding: 0 20rpx;
}

.btn-submit-rating {
  background: linear-gradient(135deg, #d4739a, #e891b0);
  border-radius: 40rpx;
  padding: 22rpx 0;
  text-align: center;
}

.btn-submit-rating text {
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
}
