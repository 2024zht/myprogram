/* pages/shop/shop.wxss */
.shop-page { padding-bottom: 120rpx; }
.shop-banner { width: 100%; }
.banner-img { width: 100%; display: block; }
.shop-info { display: flex; flex-direction: column; align-items: center; margin-top: -60rpx; position: relative; z-index: 1; }
.avatar-wrap { width: 140rpx; height: 140rpx; border-radius: 50%; overflow: hidden; border: 6rpx solid #fff; background: #fff; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1); }
.shop-avatar { width: 100%; height: 100%; }
.shop-name { margin-top: 20rpx; font-size: 36rpx; font-weight: 600; color: #333; }
.shop-actions { display: flex; justify-content: center; gap: 24rpx; margin-top: 40rpx; padding: 0 40rpx; }
.btn-enter { flex: 1; max-width: 260rpx; background: linear-gradient(135deg, #d4739a, #e891b0); border-radius: 40rpx; padding: 20rpx 0; text-align: center; }
.btn-enter-text { color: #fff; font-size: 28rpx; font-weight: 500; }
.btn-manage { flex: 1; max-width: 260rpx; border: 2rpx solid #d4739a; border-radius: 40rpx; padding: 20rpx 0; text-align: center; }
.btn-manage-text { color: #d4739a; font-size: 28rpx; font-weight: 500; }
.boss-bind { display: flex; flex-direction: column; align-items: center; margin-top: 60rpx; padding: 0 40rpx; }
.btn-bind { background: #f8f5f0; border-radius: 40rpx; padding: 20rpx 60rpx; text-align: center; border: 2rpx solid #ddd; }
.btn-bind.bound { background: #e8f5e9; border-color: #81c784; }
.btn-bind-text { color: #666; font-size: 26rpx; }
.btn-bind.bound .btn-bind-text { color: #4caf50; }
.bind-hint { margin-top: 16rpx; font-size: 22rpx; color: #bbb; }
