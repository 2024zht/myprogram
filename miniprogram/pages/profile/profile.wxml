<!--pages/profile/profile.wxml-->
<view class="profile-page">
  <view class="profile-header">
    <view class="profile-avatar">
      <text class="avatar-text">{{nickname ? nickname[0] : '?'}}</text>
    </view>
    <view class="profile-info">
      <view wx:if="{{!editing}}" class="nickname-row">
        <text class="nickname">{{nickname || '未设置昵称'}}</text>
        <view class="btn-edit" bindtap="onEditNickname">
          <text class="btn-edit-text">编辑</text>
        </view>
      </view>
      <view wx:else class="edit-row">
        <input class="nickname-input" value="{{editNickname}}" placeholder="输入昵称" bindinput="onNicknameInput" maxlength="20" />
        <view class="btn-save" bindtap="onSaveNickname">
          <text class="btn-save-text">保存</text>
        </view>
        <view class="btn-cancel" bindtap="onCancelEdit">
          <text class="btn-cancel-text">取消</text>
        </view>
      </view>
    </view>
  </view>

  <view class="profile-section">
    <view class="section-item" bindtap="onGoOrders">
      <text class="section-label">我的订单</text>
      <text class="section-arrow">&gt;</text>
    </view>
  </view>

  <view class="profile-footer">
    <text class="openid-label">OpenID</text>
    <text class="openid-value">{{openid}}</text>
  </view>
</view>
