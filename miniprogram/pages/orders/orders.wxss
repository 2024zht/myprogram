/* pages/orders/orders.wxss */
.orders-page { padding: 16rpx 0 120rpx; }
.loading-text { text-align: center; padding: 60rpx; color: #999; font-size: 26rpx; }
.empty-state { display: flex; justify-content: center; padding: 120rpx 0; }
.empty-text { color: #ccc; font-size: 28rpx; }
.order-card { background: #fff; border-radius: 16rpx; margin: 12rpx 24rpx; padding: 24rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03); }
.order-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; padding-bottom: 16rpx; border-bottom: 1rpx solid #f0f0f0; }
.order-id { font-size: 22rpx; color: #999; }
.order-items { margin-bottom: 16rpx; }
.order-item-row { display: flex; justify-content: space-between; align-items: center; padding: 8rpx 0; }
.item-name { font-size: 28rpx; color: #333; }
.item-right { display: flex; align-items: center; }
.item-price { font-size: 26rpx; color: #d4739a; margin-right: 12rpx; }
.item-qty { font-size: 24rpx; color: #999; }
.order-remark { padding: 12rpx 16rpx; background: #e8f5e9; border-radius: 8rpx; margin-bottom: 12rpx; }
.remark-text { font-size: 24rpx; color: #4caf50; }
.order-footer { display: flex; justify-content: space-between; align-items: center; padding-top: 12rpx; border-top: 1rpx solid #f0f0f0; }
.order-time { font-size: 22rpx; color: #bbb; }
.order-total { font-size: 28rpx; color: #333; font-weight: 500; }
.tag { font-size: 22rpx; padding: 4rpx 16rpx; border-radius: 6rpx; }
.tag-pending { background-color: #fff3e0; color: #ff9800; }
.tag-accepted { background-color: #e8f5e9; color: #4caf50; }
.tag-rejected { background-color: #ffebee; color: #e54545; }
.tag-done { background-color: #e0f0e0; color: #4caf50; }
.tag-cancelled { background-color: #e0e0e0; color: #999; }
