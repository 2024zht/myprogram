<!--pages/myOrders/myOrders.wxml-->
<view class="my-orders-page">
  <view wx:if="{{loading}}" class="loading-text">加载中...</view>

  <view wx:elif="{{orders.length === 0}}" class="empty-state">
    <text class="empty-text">还没有订单哦，快去点单吧</text>
  </view>

  <view wx:for="{{orders}}" wx:key="id" class="order-card">
    <view class="order-header">
      <text class="order-id">订单 #{{item.id}}</text>
      <text class="order-status status-{{item.status}}">{{item.statusText}}</text>
    </view>

    <view class="order-items">
      <view wx:for="{{item.items}}" wx:for-item="prod" wx:key="id" class="order-item-row">
        <text class="order-item-name">{{prod.name}}</text>
        <text class="order-item-qty">x{{prod.quantity}}</text>
        <text class="order-item-price">{{prod.price}}元</text>
        <view wx:if="{{item.status === 'done'}}" class="btn-review" data-product-id="{{prod.product_id}}" data-name="{{prod.name}}" catchtap="onOpenRating">
          <text class="btn-review-text">评价</text>
        </view>
      </view>
    </view>

    <view class="order-footer">
      <text class="order-time">{{item.created_at}}</text>
      <text class="order-total">合计 {{item.total_price}}元</text>
    </view>

    <view wx:if="{{item.remark}}" class="order-remark">
      <text class="remark-label">老板回复：</text>
      <text class="remark-text">{{item.remark}}</text>
    </view>

    <view wx:if="{{item.status === 'pending'}}" class="order-actions">
      <view class="btn-cancel-order" data-id="{{item.id}}" bindtap="onCancelOrder">
        <text>撤回订单</text>
      </view>
    </view>
  </view>
</view>

<!-- 评价面板 -->
<view wx:if="{{showRating}}" class="rating-mask" catchtap="onCloseRating"></view>
<view wx:if="{{showRating}}" class="rating-panel">
  <view class="rating-panel-header">
    <text class="rating-panel-title">评价商品</text>
    <text class="rating-panel-close" catchtap="onCloseRating">×</text>
  </view>
  <view class="rating-product-name">{{ratingProductName}}</view>
  <view class="rating-stars">
    <text class="rating-star-btn {{ratingValue >= 1 ? 'star-on' : ''}}" data-value="1" catchtap="onSelectStar">★</text>
    <text class="rating-star-btn {{ratingValue >= 2 ? 'star-on' : ''}}" data-value="2" catchtap="onSelectStar">★</text>
    <text class="rating-star-btn {{ratingValue >= 3 ? 'star-on' : ''}}" data-value="3" catchtap="onSelectStar">★</text>
    <text class="rating-star-btn {{ratingValue >= 4 ? 'star-on' : ''}}" data-value="4" catchtap="onSelectStar">★</text>
    <text class="rating-star-btn {{ratingValue >= 5 ? 'star-on' : ''}}" data-value="5" catchtap="onSelectStar">★</text>
  </view>
  <view class="rating-hint">{{ratingValue}} 星</view>
  <textarea class="rating-content-input" placeholder="说点什么吧（选填）" value="{{ratingContent}}" bindinput="onContentInput" maxlength="200"></textarea>
  <view class="rating-panel-footer">
    <view class="btn-submit-rating" catchtap="onSubmitRating">
      <text>提交评价</text>
    </view>
  </view>
</view>
